# Widget Server — Environment Variables

# Server
PORT=4000
NODE_ENV=development

# Backend API URL
API_URL=http://localhost:3000

# Shared secret between backend and widget-server
INTERNAL_SECRET=your_32_characters_secret_at_least_internal

# Twitch integration needed for EventSub API
TWITCH_CLIENT_ID=
TWITCH_USE_LOCAL_MOCK=false

# Allowed request origins (frontend + backend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
