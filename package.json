{
    "name": "widget-server",
    "version": "1.0.0",
    "scripts": {
        "dev": "NODE_ENV=development bun run --watch src/index.ts",
        "build": "bun build --minify --target node --outfile dist/index.js src/index.ts",
        "build:apps": "bun run scripts/build.ts",
        "addapp": "bun run scripts/addapp.ts",
        "update-apps": "bun run scripts/update-apps.ts",
        "preinstall": "bun run scripts/preinstall.ts",
        "start": "NODE_ENV=production bun run dist/index.js"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.2.3",
        "@elysiajs/static": "^1.1.2",
        "drizzle-orm": "^0.41.0",
        "elysia": "^1.2.25",
        "ioredis": "^5.6.0",
        "pg": "^8.13.3",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/pg": "^8.11.10",
        "bun-types": "latest"
    }
}